# ── Supabase (crear proyecto gratis en supabase.com) ──
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # solo servidor, nunca en el cliente

# ── Azul (pasarela de pagos RD — requiere afiliación con RNC) ──
# Deja AZUL_MERCHANT_ID vacío para usar el MODO DEMO (el pago con tarjeta se aprueba solo).
AZUL_MERCHANT_ID=
AZUL_AUTH_KEY=
AZUL_URL=https://pruebas.azul.com.do/PaymentPage/   # cambiar a producción al certificar

# ── Sitio ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Precios de publicación (en RD$) ──
# Se usan tanto en el servidor como en los botones (por eso van con NEXT_PUBLIC_).
PRECIO_ESTANDAR=2500
PRECIO_DESTACADO=6500
NEXT_PUBLIC_PRECIO_ESTANDAR=2500
NEXT_PUBLIC_PRECIO_DESTACADO=6500

# ── Pago por transferencia bancaria (recomendado para RD) ──
# Estos datos se muestran al vendedor cuando elige pagar por transferencia.
NEXT_PUBLIC_BANCO_NOMBRE=Banco Popular
NEXT_PUBLIC_BANCO_CUENTA=000-0000000-0
NEXT_PUBLIC_BANCO_TITULAR=Aprovecha.do SRL
NEXT_PUBLIC_BANCO_TIPO=Cuenta de ahorros
# WhatsApp de soporte (con código de país, solo números) para recibir el comprobante.
NEXT_PUBLIC_WHATSAPP_SOPORTE=18095550000
